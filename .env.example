# 数据库
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL="postgresql://postgres:your_postgres_password@localhost:5435/prompt_hub"

# JWT 签名密钥（必填，生产环境务必使用随机值）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# AI 接口（可选，不填则 AI 功能不可用）
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
