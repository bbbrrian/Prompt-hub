generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dimension {
  id         Int        @id @default(autoincrement())
  name       String     @unique @db.VarChar(50)
  sortOrder  Int        @default(0) @map("sort_order")
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  categories Category[]

  @@map("dimension")
}

model Category {
  id          Int              @id @default(autoincrement())
  dimensionId Int              @map("dimension_id")
  parentId    Int?             @map("parent_id")
  name        String           @db.VarChar(100)
  sortOrder   Int              @default(0) @map("sort_order")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  dimension   Dimension        @relation(fields: [dimensionId], references: [id])
  parent      Category?        @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]       @relation("CategoryTree")
  prompts     PromptCategory[]

  @@unique([dimensionId, name], map: "category_dimension_id_name_key")
  @@index([dimensionId])
  @@index([parentId])
  @@map("category")
}

model Tag {
  id        Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(50)
  color     String      @default("#00ffff") @db.VarChar(7)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  prompts   PromptTag[]
  skills    SkillTag[]
  agents    AgentTag[]

  @@map("tag")
}

enum Visibility {
  PUBLIC
  DEPARTMENT
  PRIVATE
}

model Prompt {
  id          Int              @id @default(autoincrement())
  title       String           @db.VarChar(200)
  content     String           @db.Text
  description String?          @db.VarChar(500)
  author      String?          @db.VarChar(100)
  variables   Json?
  version     Int              @default(1)
  copyCount   Int              @default(0) @map("copy_count")
  visibility  Visibility       @default(PUBLIC)
  department  String?          @db.VarChar(100)
  userId      Int?             @map("user_id")
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  isDeleted   Boolean          @default(false) @map("is_deleted")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz()
  categories  PromptCategory[]
  tags        PromptTag[]
  versions    PromptVersion[]
  workflowSteps WorkflowStep[]
  favorites   Favorite[]
  skills      Skill[]

  @@index([createdAt(sort: Desc)])
  @@map("prompt")
}

model PromptVersion {
  id          Int      @id @default(autoincrement())
  promptId    Int      @map("prompt_id")
  version     Int
  title       String   @db.VarChar(200)
  content     String   @db.Text
  description String?  @db.VarChar(500)
  author      String?  @db.VarChar(100)
  variables   Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  prompt      Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@map("prompt_version")
}

model PromptCategory {
  promptId   Int      @map("prompt_id")
  categoryId Int      @map("category_id")
  prompt     Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([promptId, categoryId])
  @@map("prompt_category")
}

model PromptTag {
  promptId Int    @map("prompt_id")
  tagId    Int    @map("tag_id")
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
  @@map("prompt_tag")
}

model Workflow {
  id          Int            @id @default(autoincrement())
  name        String         @db.VarChar(200)
  description String?        @db.VarChar(500)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz()
  userId      Int?           @map("user_id")
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  steps       WorkflowStep[]

  @@map("workflow")
}

model WorkflowStep {
  id           Int      @id @default(autoincrement())
  workflowId   Int      @map("workflow_id")
  promptId     Int      @map("prompt_id")
  stepOrder    Int      @map("step_order")
  inputMapping Json?    @map("input_mapping")
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  prompt       Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_step")
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique @db.VarChar(200)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  role         String     @default("user") @db.VarChar(20)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  favorites    Favorite[]
  prompts      Prompt[]
  workflows    Workflow[]
  skills       Skill[]
  agents       Agent[]

  @@map("user")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  promptId  Int      @map("prompt_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, promptId])
  @@index([userId])
  @@map("favorite")
}

model Skill {
  id            Int        @id @default(autoincrement())
  name          String     @db.VarChar(200)
  description   String     @db.Text
  content       String     @db.Text
  references    Json?
  scripts       Json?
  assets        Json?
  author        String?    @db.VarChar(100)
  promptId      Int?       @map("prompt_id")
  userId        Int?       @map("user_id")
  version       Int        @default(1)
  downloadCount Int        @default(0) @map("download_count")
  isDeleted     Boolean    @default(false) @map("is_deleted")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz()
  prompt        Prompt?    @relation(fields: [promptId], references: [id], onDelete: SetNull)
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  tags          SkillTag[]

  @@index([createdAt(sort: Desc)])
  @@map("skill")
}

model SkillTag {
  skillId Int   @map("skill_id")
  tagId   Int   @map("tag_id")
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([skillId, tagId])
  @@map("skill_tag")
}

// 注意：修改此文件后需执行 npx prisma migrate dev --name add-agent 生成迁移

model Agent {
  id            Int        @id @default(autoincrement())
  name          String     @db.VarChar(200)
  description   String     @db.Text
  systemPrompt  String     @db.Text @map("system_prompt")
  tools         Json?
  model         String?    @db.VarChar(100)
  author        String?    @db.VarChar(100)
  userId        Int?       @map("user_id")
  version       Int        @default(1)
  isDeleted     Boolean    @default(false) @map("is_deleted")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz()
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  tags          AgentTag[]

  @@index([createdAt(sort: Desc)])
  @@map("agent")
}

model AgentTag {
  agentId Int   @map("agent_id")
  tagId   Int   @map("tag_id")
  agent   Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([agentId, tagId])
  @@map("agent_tag")
}
